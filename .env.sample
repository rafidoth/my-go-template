 --- Primary ---
MYAPP_PRIMARY.ENV=development

# --- Server ---
MYAPP_SERVER.PORT=8080
MYAPP_SERVER.READ_TIMEOUT=30
MYAPP_SERVER.WRITE_TIMEOUT=30
MYAPP_SERVER.IDLE_TIMEOUT=120
MYAPP_SERVER.CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Database ---
MYAPP_DATABASE.HOST=localhost
MYAPP_DATABASE.PORT=5432
MYAPP_DATABASE.USER=postgres
MYAPP_DATABASE.PASSWORD=postgres
MYAPP_DATABASE.NAME=myapp_dev
MYAPP_DATABASE.SSL_MODE=disable
MYAPP_DATABASE.MAX_OPEN_CONNS=25
MYAPP_DATABASE.MAX_IDLE_CONNS=10
MYAPP_DATABASE.CONN_MAX_LIFETIME=300
MYAPP_DATABASE.CONN_MAX_IDLE_TIME=30

# --- Auth ---
MYAPP_AUTH.SECRET_KEY=your-secret-key-change-me

# --- Observability ---
MYAPP_OBSERVABILITY.SERVICE_NAME=myapp
MYAPP_OBSERVABILITY.ENVIRONMENT=development

# Logging
MYAPP_OBSERVABILITY.LOGGING.LEVEL=debug
MYAPP_OBSERVABILITY.LOGGING.FORMAT=console
MYAPP_OBSERVABILITY.LOGGING.SLOW_QUERY_THRESHOLD=100ms

# New Relic (leave license_key empty to disable)
MYAPP_OBSERVABILITY.NEW_RELIC.LICENSE_KEY=empty
MYAPP_OBSERVABILITY.NEW_RELIC.APP_LOG_FORWARDING_ENABLED=true
MYAPP_OBSERVABILITY.NEW_RELIC.DISTRIBUTED_TRACING_ENABLED=true
MYAPP_OBSERVABILITY.NEW_RELIC.DEBUG_LOGGING=false

# Health Checks
MYAPP_OBSERVABILITY.HEALTH_CHECKS.ENABLED=true
MYAPP_OBSERVABILITY.HEALTH_CHECKS.INTERVAL=30s
MYAPP_OBSERVABILITY.HEALTH_CHECKS.TIMEOUT=5s
MYAPP_OBSERVABILITY.HEALTH_CHECKS.CHECKS=database,redis
